      ]
    },
    {
      "info": {
        "name": "Research",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Run AI research task",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.tavily.com/research"
          },
          "docs": "Run an AI-driven research task that aggregates, ranks, and cites sources."
        }
      ]
